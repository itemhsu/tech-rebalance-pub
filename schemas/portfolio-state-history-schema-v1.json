{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "portfolio-state-history-schema-v1.json",
  "title": "portfolio_state_history.json — NAV 歷史（TWR/縫合靠它）",
  "type": "object",
  "required": ["history"],
  "additionalProperties": true,
  "properties": {
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "nav"],
        "additionalProperties": true,
        "properties": {
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "nav":  { "type": "number" }
        }
      }
    },
    "initial_nav": { "type": "number" },
    "start_date":  { "type": "string" }
  }
}
