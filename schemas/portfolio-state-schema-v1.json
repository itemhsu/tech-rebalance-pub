{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "portfolio-state-schema-v1.json",
  "title": "portfolio_state.json — 最新持倉快照（冪等守門+報告靠它）",
  "type": "object",
  "required": ["date", "nav", "cash", "positions"],
  "additionalProperties": true,
  "properties": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "nav":  { "type": "number" },
    "cash": { "type": "number" },
    "positions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["symbol", "qty"],
        "additionalProperties": true,
        "properties": {
          "symbol": { "type": "string", "minLength": 1 },
          "qty":    { "type": "number" }
        }
      }
    }
  }
}
