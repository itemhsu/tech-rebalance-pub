{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "universe-schema-v1.json",
  "title": "data/universe.json — 股票宇宙",
  "type": "object",
  "required": ["stocks"],
  "additionalProperties": true,
  "properties": {
    "stocks": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "last_updated": { "type": "string" },
    "description":  { "type": "string" }
  }
}
