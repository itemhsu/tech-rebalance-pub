{
  "$schema": "https://itemhsu.github.io/tech-rebalance/strategies/strategy-schema-v3.json",
  "id": "d2p2t6",
  "version": "3.0",
  "schema_version": "3.0.0",
  "meta": {
    "name": "D2P2T6",
    "description": "軍火×2 + 醫藥×2 + 科技×6 = 10 檔等權重，每日再平衡",
    "author": "itemhsu",
    "created_at": "2024-03-01",
    "tags": [
      "多元分散",
      "軍火",
      "醫藥",
      "科技",
      "美股"
    ],
    "benchmark": "QQQ",
    "asset_class": "equity",
    "market": "US_STOCK"
  },
  "universe": {
    "type": "grouped",
    "groups": [
      {
        "id": "defense",
        "label": "🛡️ 軍火",
        "source": {
          "type": "inline",
          "symbols": [
            "LMT",
            "RTX",
            "NOC",
            "GD",
            "HII",
            "LHX",
            "LDOS",
            "TDG",
            "TXT",
            "CW"
          ]
        }
      },
      {
        "id": "pharma",
        "label": "💊 醫藥",
        "source": {
          "type": "inline",
          "symbols": [
            "JNJ",
            "PFE",
            "MRK",
            "LLY",
            "AMGN",
            "BMY",
            "GILD",
            "ABT",
            "BIIB",
            "REGN"
          ]
        }
      },
      {
        "id": "tech",
        "label": "💻 科技",
        "source": {
          "type": "inline",
          "symbols": [
            "AAPL",
            "MSFT",
            "NVDA",
            "GOOGL",
            "META",
            "AMZN",
            "TSLA",
            "ORCL",
            "AMD",
            "AVGO"
          ]
        }
      }
    ]
  },
  "selection": {
    "method": "top_n_per_group",
    "metric": "market_cap",
    "group_quotas": {
      "defense": 2,
      "pharma": 2,
      "tech": 6
    }
  },
  "portfolio": {
    "weighting": "equal",
    "target_n": 10,
    "min_weight_pct": 5.0,
    "max_weight_pct": 30.0,
    "cash_buffer_pct": 2.0,
    "custom_weights": null,
    "allow_fractional_shares": true,
    "min_order_value": 50
  },
  "rebalancing": {
    "frequency": "daily",
    "trigger": {
      "type": "any",
      "conditions": [
        {
          "kind": "composition_change"
        },
        {
          "kind": "weight_drift",
          "threshold_pct": 3.0
        }
      ]
    },
    "min_trade_value_usd": 50,
    "order_type": "market",
    "sell_before_buy": true
  },
  "risk": {
    "max_single_position_pct": 20.0,
    "min_positions": 5,
    "allow_fractional_shares": true,
    "trailing_stop_pct": 0.12,
    "halt_new_entries_when_drawdown_pct_exceeds": 0.15
  },
  "execution": {
    "broker": "alpaca",
    "account_type": "paper",
    "order_type": "market",
    "time_in_force": "day",
    "submit_after_market_open_minutes": 15,
    "earnings_blackout_before_days": 2,
    "earnings_blackout_after_days": 1,
    "retry": {
      "max_attempts": 3,
      "backoff_seconds": 5
    }
  },
  "dashboard": {
    "title": "D2P2T6 Dashboard",
    "subtitle": "軍火×2 + 醫藥×2 + 科技×6 = 10 檔等權重",
    "accent_color": "#6366f1",
    "portfolio_label": "D2P2T6 組合",
    "rankings": {
      "type": "universe_groups",
      "title": "三大宇宙即時排名",
      "show_top_n_per_group": 5,
      "group_labels": {
        "defense": "🛡️ 軍火 TOP5",
        "pharma": "💊 醫藥 TOP5",
        "tech": "💻 科技 TOP10"
      }
    },
    "extra_sections": [
      {
        "type": "portfolio_badges",
        "title": "本月 D2P2T6 組合"
      }
    ]
  },
  "email": {
    "subject_template": "[D2P2T6 #{account_id}] {date} NAV ${nav:,.0f} ({today_change_pct:+.2f}%)",
    "recipients_env": "EMAIL_RECIPIENTS",
    "sections": [
      "header",
      "kpi",
      "strategy_card",
      "portfolio_badges",
      "positions_table",
      "rankings",
      "today_events",
      "harvest_plan",
      "trades",
      "cta",
      "footer"
    ]
  },
  "backtest": {
    "initial_cash": 100000,
    "start_date": "2010-01-01",
    "enabled": true,
    "color": "#06b6d4",
    "group": "diversified",
    "order": 202,
    "label": "D2P2T6"
  }
}
