{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "strategy-schema-v3.json",
  "title": "Strategy Definition Schema v3",
  "description": "Unified schema: backwards-compatible with v1, additive with v2 algorithmic features. Simple strategies use only required blocks; advanced strategies add optional indicator/signal blocks.",
  "type": "object",

  "required": ["$schema", "id", "version", "meta", "universe", "selection", "portfolio", "rebalancing", "risk", "dashboard", "email"],
  "additionalProperties": false,

  "properties": {

    "$schema": { "type": "string" },

    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Unique strategy identifier (lowercase + underscores)"
    },

    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Strategy version (e.g. '1.0', '2.3')"
    },

    "schema_version": {
      "type": "string",
      "enum": ["3.0.0"],
      "description": "Schema version. Omit for v1-compatible files; set to '3.0.0' for new v3 features."
    },

    "meta": {
      "type": "object",
      "required": ["name", "description", "author", "created_at"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "author":      { "type": "string" },
        "created_at":  { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "tags":        { "type": "array", "items": { "type": "string" } },
        "benchmark":   { "type": "string" },
        "asset_class": {
          "type": "string",
          "enum": ["equity", "etf", "crypto", "mixed"],
          "default": "equity",
          "description": "[v3] Asset class for this strategy"
        },
        "market": {
          "type": "string",
          "enum": ["US_STOCK", "US_ETF", "GLOBAL"],
          "default": "US_STOCK",
          "description": "[v3] Target market"
        },
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "[v3] Whether strategy is active"
        }
      }
    },

    "universe": {
      "type": "object",
      "required": ["type"],
      "description": "Stock universe definition. Three modes: single (v1), grouped (v1/D2P2T6), exchange_filter (v3 new).",
      "oneOf": [
        {
          "description": "Single universe — v1 compatible",
          "properties": {
            "type":   { "const": "single" },
            "source": { "$ref": "#/definitions/universe_source" }
          },
          "required": ["type", "source"],
          "additionalProperties": false
        },
        {
          "description": "Grouped universe — required for D2P2T6-style multi-sector strategies",
          "properties": {
            "type": { "const": "grouped" },
            "groups": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "label", "source"],
                "additionalProperties": false,
                "properties": {
                  "id":     { "type": "string" },
                  "label":  { "type": "string" },
                  "source": { "$ref": "#/definitions/universe_source" }
                }
              }
            }
          },
          "required": ["type", "groups"],
          "additionalProperties": false
        },
        {
          "description": "[v3] Exchange filter universe — dynamic screener for advanced algorithmic strategies",
          "properties": {
            "type":                          { "const": "exchange_filter" },
            "exchanges":                     { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "include_symbols":               { "type": "array", "items": { "type": "string" } },
            "exclude_symbols":               { "type": "array", "items": { "type": "string" } },
            "exclude_sectors":               { "type": "array", "items": { "type": "string" } },
            "exclude_industries":            { "type": "array", "items": { "type": "string" } },
            "min_price":                     { "type": "number", "minimum": 0 },
            "min_market_cap":                { "type": "number", "minimum": 0 },
            "min_avg_volume_20d":            { "type": "number", "minimum": 0 },
            "min_history_days":              { "type": "integer", "minimum": 1 },
            "max_candidates_before_filter":  { "type": "integer", "minimum": 1 }
          },
          "required": ["type", "exchanges"],
          "additionalProperties": false
        }
      ]
    },

    "selection": {
      "type": "object",
      "required": ["method"],
      "description": "Stock selection logic. method determines required sub-fields.",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["top_n_by_metric", "top_n_per_group", "factor_score", "weighted_percentile", "weighted_percentile_per_group", "buy_and_hold"],
          "description": "top_n_by_metric / top_n_per_group / factor_score: v1 compatible. weighted_percentile: v3 advanced (requires top-level 'ranking' block)."
        }
      },
      "if":   { "properties": { "method": { "const": "top_n_by_metric" } } },
      "then": {
        "required": ["metric", "n"],
        "properties": {
          "method":          { "const": "top_n_by_metric" },
          "metric":          { "$ref": "#/definitions/metric_v1" },
          "n":               { "type": "integer", "minimum": 1 },
          "min_price":       { "type": "number", "minimum": 0 },
          "lookback_days":   { "type": "integer", "minimum": 1 },
          "exclude_symbols": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      },
      "else": {
        "if":   { "properties": { "method": { "const": "top_n_per_group" } } },
        "then": {
          "required": ["metric", "group_quotas"],
          "properties": {
            "method":       { "const": "top_n_per_group" },
            "metric":       { "$ref": "#/definitions/metric_v1" },
            "group_quotas": {
              "type": "object",
              "additionalProperties": { "type": "integer", "minimum": 1 }
            }
          },
          "additionalProperties": false
        },
        "else": {
          "if":   { "properties": { "method": { "const": "factor_score" } } },
          "then": {
            "required": ["factors", "n"],
            "properties": {
              "method":  { "const": "factor_score" },
              "factors": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["metric", "weight"],
                  "additionalProperties": false,
                  "properties": {
                    "metric": { "$ref": "#/definitions/metric_v1" },
                    "weight": { "type": "number", "minimum": 0, "maximum": 1 }
                  }
                }
              },
              "n": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          },
          "else": {
            "description": "[v3] weighted_percentile / weighted_percentile_per_group / buy_and_hold",
            "if":   { "properties": { "method": { "const": "weighted_percentile" } } },
            "then": {
              "required": ["n"],
              "properties": {
                "method":           { "const": "weighted_percentile" },
                "n":                { "type": "integer", "minimum": 1, "description": "Final number of positions to hold" },
                "watchlist_top_n":  { "type": "integer", "minimum": 1, "description": "Wider candidate pool before ranking/scoring" },
                "watchlist_metric": {
                  "type": "string",
                  "enum": ["market_cap", "price_momentum_3m", "price_momentum_6m", "price_momentum_12m"],
                  "default": "market_cap",
                  "description": "Metric used to pre-select watchlist_top_n candidates before ranking"
                },
                "min_score":        { "type": "number", "minimum": 0, "maximum": 100 }
              },
              "additionalProperties": false
            },
            "else": {
              "description": "[v3] weighted_percentile_per_group: per-group watchlist by metric → rank by 'ranking' factors → per-group quotas",
              "properties": {
                "method":            { "enum": ["weighted_percentile_per_group", "buy_and_hold"] },
                "group_watchlist":   { "type": "object", "additionalProperties": { "type": "integer", "minimum": 1 } },
                "group_quotas":      { "type": "object", "additionalProperties": { "type": "integer", "minimum": 1 } },
                "watchlist_metric":  {
                  "type": "string",
                  "enum": ["market_cap", "price_momentum_3m", "price_momentum_6m", "price_momentum_12m"],
                  "default": "market_cap"
                },
                "n":                 { "type": "integer", "minimum": 1 },
                "min_score":         { "type": "number", "minimum": 0, "maximum": 100 }
              }
            }
          }
        }
      }
    },

    "portfolio": {
      "type": "object",
      "required": ["weighting", "target_n"],
      "additionalProperties": false,
      "properties": {
        "weighting":              { "type": "string", "enum": ["equal", "market_cap", "factor_score", "custom"] },
        "target_n":               { "type": "integer", "minimum": 1 },
        "min_weight_pct":         { "type": "number", "minimum": 0, "maximum": 100 },
        "max_weight_pct":         { "type": "number", "minimum": 0, "maximum": 100 },
        "cash_buffer_pct":        { "type": "number", "minimum": 0, "maximum": 50 },
        "custom_weights":         { "oneOf": [{ "type": "null" }, { "type": "object", "additionalProperties": { "type": "number" } }] },
        "allow_fractional_shares":{ "type": "boolean", "description": "[v3] Permit fractional share orders" },
        "min_order_value":        { "type": "number", "minimum": 0, "description": "[v3] Minimum USD order size" }
      }
    },

    "rebalancing": {
      "type": "object",
      "required": ["frequency", "trigger", "order_type"],
      "additionalProperties": false,
      "properties": {
        "frequency":                       { "type": "string", "enum": ["daily", "weekly", "monthly", "none"] },
        "rebalance_on":                    { "type": "string", "enum": ["first_trading_day", "last_trading_day"] },
        "day_of_week":                     { "type": "string", "enum": ["MON", "TUE", "WED", "THU", "FRI"], "description": "[v3] For weekly strategies" },
        "time":                            { "type": "string", "pattern": "^\\d{2}:\\d{2}:\\d{2}$", "description": "[v3] e.g. '09:45:00'" },
        "timezone":                        { "type": "string", "description": "[v3] e.g. 'America/New_York'" },
        "trigger": {
          "type": "object",
          "required": ["type", "conditions"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["any", "all"] },
            "conditions": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["kind"],
                "additionalProperties": false,
                "properties": {
                  "kind":          { "type": "string", "enum": ["composition_change", "weight_drift", "scheduled", "entry_signal"] },
                  "threshold_pct": { "type": "number", "minimum": 0 }
                }
              }
            }
          }
        },
        "min_trade_value_usd":             { "type": "number", "minimum": 0 },
        "order_type":                      { "type": "string", "enum": ["market", "limit"] },
        "sell_before_buy":                 { "type": "boolean" },
        "replace_if_rank_below":           { "type": "integer", "description": "[v3] Exit position if rank drops below this" },
        "allow_partial_rebalance":         { "type": "boolean", "description": "[v3] Allow rebalancing subset of positions" },
        "max_turnover_pct_per_rebalance":  { "type": "number", "minimum": 0, "maximum": 1, "description": "[v3] Max portfolio turnover per rebalance cycle" }
      }
    },

    "risk": {
      "type": "object",
      "required": ["max_single_position_pct", "min_positions"],
      "additionalProperties": false,
      "properties": {
        "max_single_position_pct":                  { "type": "number", "minimum": 0, "maximum": 100 },
        "min_positions":                            { "type": "integer", "minimum": 1 },
        "halt_on_nav_drop_pct":                     { "type": "number", "minimum": 0, "maximum": 100 },
        "halt_lookback_days":                       { "type": "integer", "minimum": 1 },
        "allow_fractional_shares":                  { "type": "boolean" },
        "trailing_stop_pct":                        { "type": "number", "minimum": 0, "maximum": 1, "description": "[v3] e.g. 0.1 = 10% trailing stop" },
        "stop_loss_atr_multiple":                   { "type": "number", "minimum": 0, "description": "[v3] Stop loss = entry - N × ATR14" },
        "take_profit_pct":                          { "type": "number", "minimum": 0, "description": "[v3] e.g. 0.25 = 25% take profit" },
        "cooldown_after_stop_loss_days":            { "type": "integer", "minimum": 0, "description": "[v3] Days to wait before re-entering same symbol after stop" },
        "halt_new_entries_when_drawdown_pct_exceeds":{ "type": "number", "minimum": 0, "maximum": 1, "description": "[v3] Pause new buys above this portfolio drawdown" },
        "max_daily_loss_pct":                       { "type": "number", "minimum": 0, "maximum": 1, "description": "[v3] Intraday circuit breaker" },
        "beta_limit":                               { "type": "number", "minimum": 0, "description": "[v3] Reject symbols above this beta" },
        "volatility_limit_annualized":              { "type": "number", "minimum": 0, "description": "[v3] Reject symbols above this annualized vol" },
        "max_symbol_gap_down_pct":                  { "type": "number", "minimum": 0, "description": "[v3] Skip order if symbol gapped down more than this" }
      }
    },

    "execution": {
      "type": "object",
      "description": "[v3] Optional execution configuration. Broker/account defaults can live here.",
      "additionalProperties": false,
      "properties": {
        "broker":                            { "type": "string", "enum": ["alpaca"] },
        "account_type":                      { "type": "string", "enum": ["paper", "live"] },
        "order_type":                        { "type": "string", "enum": ["market", "limit"] },
        "time_in_force":                     { "type": "string", "enum": ["day", "gtc", "ioc"] },
        "submit_after_market_open_minutes":  { "type": "integer", "minimum": 0 },
        "earnings_blackout_before_days":     { "type": "integer", "minimum": 0, "description": "Skip trades N days before earnings" },
        "earnings_blackout_after_days":      { "type": "integer", "minimum": 0, "description": "Skip trades N days after earnings" },
        "slippage_bps":                      { "type": "number", "minimum": 0 },
        "commission_bps":                    { "type": "number", "minimum": 0 },
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_attempts":    { "type": "integer", "minimum": 1 },
            "backoff_seconds": { "type": "number", "minimum": 0 }
          }
        }
      }
    },

    "indicators": {
      "type": "array",
      "description": "[v3] Technical indicator definitions. Referenced by filters, entry_signals, exit_signals.",
      "items": { "$ref": "#/definitions/indicator" }
    },

    "derived_factors": {
      "type": "array",
      "description": "[v3] Computed fields using indicator outputs and price data.",
      "items": {
        "type": "object",
        "required": ["name", "formula"],
        "additionalProperties": false,
        "properties": {
          "name":    { "type": "string" },
          "formula": { "type": "string", "description": "Expression using indicator names, lag(), price fields" }
        }
      }
    },

    "filters": {
      "type": "object",
      "description": "[v3] Pre-selection filters applied after universe, before ranking/selection.",
      "additionalProperties": false,
      "properties": {
        "fundamental": { "$ref": "#/definitions/condition_group" },
        "technical":   { "$ref": "#/definitions/condition_group" }
      }
    },

    "ranking": {
      "type": "object",
      "description": "[v3] Required when selection.method == 'weighted_percentile'. Defines multi-factor scoring.",
      "required": ["method", "factors"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "enum": ["weighted_percentile_score"] },
        "normalization": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "method":           { "type": "string", "enum": ["cross_sectional_percentile", "z_score", "min_max"] },
            "clip_percentiles": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
            "handle_missing":   { "type": "string", "enum": ["exclude_symbol", "fill_median", "fill_zero"] }
          }
        },
        "factors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["field", "weight", "direction"],
            "additionalProperties": false,
            "properties": {
              "field":     { "type": "string" },
              "weight":    { "type": "number", "minimum": 0, "maximum": 1 },
              "direction": { "type": "string", "enum": ["asc", "desc"] }
            }
          }
        },
        "tie_breakers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered list of fields to break ranking ties"
        }
      }
    },

    "entry_signals": {
      "type": "object",
      "description": "[v3] Additional entry conditions applied on top of ranking. Logic: AND/OR over conditions.",
      "additionalProperties": false,
      "required": ["logic", "conditions"],
      "properties": {
        "logic":      { "type": "string", "enum": ["AND", "OR"] },
        "conditions": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/signal_condition" } }
      }
    },

    "exit_signals": {
      "type": "object",
      "description": "[v3] Position exit conditions. Logic OR means first-hit exits. Evaluated daily per position.",
      "additionalProperties": false,
      "required": ["logic", "conditions"],
      "properties": {
        "logic":      { "type": "string", "enum": ["AND", "OR"] },
        "conditions": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/signal_condition" } }
      }
    },

    "backtest": {
      "type": "object",
      "description": "[v3] Backtesting configuration.",
      "additionalProperties": false,
      "properties": {
        "initial_cash":        { "type": "number", "minimum": 0 },
        "benchmark":           { "type": "string" },
        "start_date":          { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "end_date":            { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "rebalance_at":        { "type": "string", "enum": ["next_open", "close", "intraday"] },
        "fill_price":          { "type": "string", "enum": ["next_open", "close", "vwap"] },
        "include_slippage":    { "type": "boolean" },
        "include_commission":  { "type": "boolean" },
        "color":               { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$", "description": "tool_v2 dashboard line/bar color" },
        "group":               { "type": "string", "enum": ["momentum", "diversified", "benchmark", "hedged", "weekly", "other"], "description": "tool_v2 grouping in sidebar" },
        "order":               { "type": "integer", "description": "tool_v2 display order" },
        "label":               { "type": "string", "description": "tool_v2 short label (defaults to meta.name)" },
        "enabled":             { "type": "boolean", "description": "tool_v2 include in backtest (defaults to true)" },
        "metrics": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["cagr","annualized_volatility","sharpe","sortino","max_drawdown","calmar","win_rate","profit_factor","turnover","alpha","beta"]
          }
        }
      }
    },

    "dashboard": {
      "type": "object",
      "required": ["title", "accent_color", "portfolio_label", "rankings"],
      "additionalProperties": false,
      "properties": {
        "title":           { "type": "string" },
        "subtitle":        { "type": "string" },
        "accent_color":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "portfolio_label": { "type": "string" },
        "rankings": {
          "type": "object",
          "required": ["type", "title"],
          "additionalProperties": false,
          "properties": {
            "type":               { "type": "string", "enum": ["market_cap_list", "universe_groups", "factor_score_list"] },
            "title":              { "type": "string" },
            "show_top_n":         { "type": "integer", "minimum": 1 },
            "show_top_n_per_group":{ "type": "integer", "minimum": 1 },
            "group_labels":       { "type": "object", "additionalProperties": { "type": "string" } }
          }
        },
        "extra_sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "additionalProperties": false,
            "properties": {
              "type":  { "type": "string" },
              "title": { "type": "string" }
            }
          }
        }
      }
    },

    "email": {
      "type": "object",
      "required": ["subject_template", "recipients_env", "sections"],
      "additionalProperties": false,
      "properties": {
        "subject_template":       { "type": "string" },
        "recipients_env":         { "type": "string" },
        "sections":               { "type": "array", "items": { "type": "string" } },
        "sections_rebalance_day": { "type": "array", "items": { "type": "string" } },
        "sections_normal_day":    { "type": "array", "items": { "type": "string" } }
      }
    }
  },

  "definitions": {

    "universe_source": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "properties": {
            "type":          { "const": "csv_file" },
            "path":          { "type": "string" },
            "symbol_column": { "type": "string" }
          },
          "required": ["type", "path", "symbol_column"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type":    { "const": "inline" },
            "symbols": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["type", "symbols"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "json_file" },
            "path": { "type": "string" },
            "key":  { "type": "string" }
          },
          "required": ["type", "path", "key"],
          "additionalProperties": false
        }
      ]
    },

    "metric_v1": {
      "type": "string",
      "enum": [
        "market_cap",
        "price_momentum_1m",
        "price_momentum_3m",
        "price_momentum_6m",
        "price_momentum_12m",
        "revenue_growth_yoy",
        "dividend_yield"
      ]
    },

    "indicator": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": true,
      "properties": {
        "name":    { "type": "string" },
        "type":    { "type": "string", "enum": ["SMA","EMA","RSI","MACD","ADX","ATR","BOLLINGER_BANDS","OBV","VWAP","ROC"] },
        "source":  { "type": "string" },
        "period":  { "type": "integer", "minimum": 1 },
        "fast":    { "type": "integer", "minimum": 1 },
        "slow":    { "type": "integer", "minimum": 1 },
        "signal":  { "type": "integer", "minimum": 1 },
        "stddev":  { "type": "number" },
        "outputs": { "type": "array", "items": { "type": "string" } },
        "session": { "type": "string" }
      }
    },

    "condition_group": {
      "type": "object",
      "required": ["logic", "conditions"],
      "additionalProperties": false,
      "properties": {
        "logic": { "type": "string", "enum": ["AND", "OR"] },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["field", "op", "value"],
            "additionalProperties": false,
            "properties": {
              "field": { "type": "string" },
              "op":    { "type": "string", "enum": [">", "<", ">=", "<=", "==", "!=", "between"] },
              "value": { "oneOf": [{ "type": "number" }, { "type": "string" }, { "type": "array" }] }
            }
          }
        }
      }
    },

    "signal_condition": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "rank_in_top_n", "rank_falls_below",
            "crosses_above", "crosses_below",
            "field_compare",
            "stop_loss", "trailing_stop", "take_profit"
          ]
        },
        "n":            { "type": "integer" },
        "rank":         { "type": "integer" },
        "left":         { "type": "string" },
        "right":        { "type": "string" },
        "lookback_bars":{ "type": "integer" },
        "field":        { "type": "string" },
        "op":           { "type": "string", "enum": [">", "<", ">=", "<=", "==", "!="] },
        "value":        { "oneOf": [{ "type": "number" }, { "type": "string" }] },
        "mode":         { "type": "string", "enum": ["atr_multiple", "fixed_pct"] },
        "atr":          { "type": "string" },
        "multiple":     { "type": "number" },
        "pct":          { "type": "number" }
      }
    }
  }
}
