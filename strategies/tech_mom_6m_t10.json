{
  "$schema": "strategy-schema-v3.json",
  "id": "tech_mom_6m_t10",
  "version": "1.0",
  "schema_version": "3.0.0",

  "meta": {
    "name": "科技 6m動能 TOP10",
    "description": "科技股市值前 15 → 再依 6 個月動能取前 10、等權重。股池由市場決定（美股／台股）。",
    "author": "itemhsu",
    "created_at": "2026-06-09",
    "tags": ["科技", "動能", "top10", "market-agnostic"],
    "benchmark": "QQQ",
    "asset_class": "equity",
    "market": "ANY"
  },

  "universe": {
    "type": "single",
    "source": { "type": "market_group", "group": "tech" }
  },

  "selection": {
    "method": "weighted_percentile",
    "n": 10,
    "watchlist_top_n": 15,
    "watchlist_metric": "market_cap"
  },

  "ranking": {
    "method": "weighted_percentile_score",
    "factors": [
      { "field": "price_momentum_6m", "weight": 1.0, "direction": "desc" }
    ]
  },

  "portfolio": {
    "weighting": "equal",
    "target_n": 10,
    "min_weight_pct": 5.0,
    "max_weight_pct": 30.0,
    "cash_buffer_pct": 2.0,
    "custom_weights": null,
    "allow_fractional_shares": true,
    "min_order_value": 50
  },

  "rebalancing": {
    "frequency": "monthly",
    "rebalance_on": "first_trading_day",
    "trigger": { "type": "any", "conditions": [{ "kind": "scheduled" }] },
    "order_type": "market",
    "sell_before_buy": true
  },

  "risk": { "max_single_position_pct": 30.0, "min_positions": 5 },

  "backtest": {
    "initial_cash": 100000,
    "start_date": "2015-01-01",
    "enabled": true,
    "color": "#f59e0b",
    "group": "momentum",
    "order": 151,
    "label": "科技Mom6m-T10"
  },

  "dashboard": {
    "title": "科技 6m動能 TOP10",
    "subtitle": "市值前15 → 6m動能前10 · 等權重 · 股池依市場",
    "accent_color": "#f59e0b",
    "portfolio_label": "前10名持股",
    "rankings": { "type": "market_cap_list", "title": "科技市值排名", "show_top_n": 25 }
  },

  "email": {
    "subject_template": "[TECHMOM6 #{account_id}] {date} NAV {nav:,.0f}",
    "recipients_env": "EMAIL_RECIPIENT",
    "sections": ["kpi"]
  }
