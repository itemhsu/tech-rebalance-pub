{
  "$schema": "strategy-schema-v3.json",
  "id": "tech_top10",
  "version": "1.0",
  "schema_version": "3.0.0",

  "meta": {
    "name": "科技 TOP10（市值）",
    "description": "科技股市值前 10、等權重。股池由市場決定：美股帳戶用美股科技、台股帳戶用台股科技。",
    "author": "itemhsu",
    "created_at": "2026-06-09",
    "tags": ["科技", "市值", "top10", "market-agnostic"],
    "benchmark": "QQQ",
    "asset_class": "equity",
    "market": "ANY"
  },

  "universe": {
    "type": "single",
    "source": { "type": "market_group", "group": "tech" }
  },

  "selection": {
    "method": "top_n_by_metric",
    "metric": "market_cap",
    "n": 10,
    "min_price": 5.0,
    "exclude_symbols": []
  },

  "portfolio": {
    "weighting": "equal",
    "target_n": 10,
    "min_weight_pct": 5.0,
    "max_weight_pct": 30.0,
    "cash_buffer_pct": 2.0,
    "custom_weights": null,
    "allow_fractional_shares": true,
    "min_order_value": 50
  },

  "rebalancing": {
    "frequency": "monthly",
    "rebalance_on": "first_trading_day",
    "trigger": { "type": "any", "conditions": [{ "kind": "scheduled" }] },
    "order_type": "market",
    "sell_before_buy": true
  },

  "risk": { "max_single_position_pct": 30.0, "min_positions": 5 },

  "backtest": {
    "initial_cash": 100000,
    "start_date": "2015-01-01",
    "enabled": true,
    "color": "#10b981",
    "group": "diversified",
    "order": 150,
    "label": "科技TOP10(市值)"
  },

  "dashboard": {
    "title": "科技 TOP10（市值）",
    "subtitle": "科技股市值前 10 · 等權重 · 股池依市場",
    "accent_color": "#10b981",
    "portfolio_label": "前10名持股",
    "rankings": { "type": "market_cap_list", "title": "科技市值排名", "show_top_n": 25 }
  },

  "email": {
    "subject_template": "[TECH10 #{account_id}] {date} NAV {nav:,.0f}",
    "recipients_env": "EMAIL_RECIPIENT",
    "sections": ["kpi"]
  }
}
