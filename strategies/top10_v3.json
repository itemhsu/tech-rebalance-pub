{
  "$schema": "https://itemhsu.github.io/tech-rebalance/strategies/strategy-schema-v3.json",
  "id": "top10",
  "version": "3.0",
  "schema_version": "3.0.0",
  "meta": {
    "name": "科技股 TOP10",
    "description": "前 10 大市值科技股，每日等權重再平衡",
    "author": "itemhsu",
    "created_at": "2024-01-15",
    "tags": [
      "科技",
      "市值",
      "美股"
    ],
    "benchmark": "QQQ",
    "asset_class": "equity",
    "market": "US_STOCK"
  },
  "universe": {
    "type": "single",
    "source": {
      "type": "json_file",
      "path": "data/universe.json",
      "key": "stocks"
    }
  },
  "selection": {
    "method": "top_n_by_metric",
    "metric": "market_cap",
    "n": 10,
    "min_price": 5.0,
    "exclude_symbols": []
  },
  "portfolio": {
    "weighting": "equal",
    "target_n": 10,
    "min_weight_pct": 5.0,
    "max_weight_pct": 30.0,
    "cash_buffer_pct": 2.0,
    "custom_weights": null,
    "allow_fractional_shares": true,
    "min_order_value": 50
  },
  "rebalancing": {
    "frequency": "monthly",
    "rebalance_on": "first_trading_day",
    "trigger": {
      "type": "any",
      "conditions": [
        {
          "kind": "scheduled"
        }
      ]
    },
    "min_trade_value_usd": 50,
    "order_type": "market",
    "sell_before_buy": true
  },
  "risk": {
    "max_single_position_pct": 20.0,
    "min_positions": 5,
    "allow_fractional_shares": true,
    "trailing_stop_pct": 0.12,
    "halt_new_entries_when_drawdown_pct_exceeds": 0.15
  },
  "execution": {
    "broker": "alpaca",
    "account_type": "paper",
    "order_type": "market",
    "time_in_force": "day",
    "submit_after_market_open_minutes": 15,
    "earnings_blackout_before_days": 2,
    "earnings_blackout_after_days": 1,
    "retry": {
      "max_attempts": 3,
      "backoff_seconds": 5
    }
  },
  "dashboard": {
    "title": "科技股 TOP10 Dashboard",
    "subtitle": "前 10 大市值科技股 · 等權重 10%",
    "accent_color": "#38bdf8",
    "portfolio_label": "前10名持股",
    "rankings": {
      "type": "market_cap_list",
      "title": "科技股市值排名",
      "show_top_n": 20
    },
    "extra_sections": []
  },
  "email": {
    "subject_template": "[TOP10 #{account_id}] {date} NAV ${nav:,.0f} ({today_change_pct:+.2f}%)",
    "recipients_env": "EMAIL_RECIPIENTS",
    "sections": [
      "header",
      "kpi",
      "strategy_card",
      "portfolio_badges",
      "positions_table",
      "rankings",
      "today_events",
      "trades",
      "cta",
      "footer"
    ]
  },
  "backtest": {
    "initial_cash": 100000,
    "start_date": "2010-01-01",
    "enabled": true,
    "color": "#10b981",
    "group": "diversified",
    "order": 201,
    "label": "Top10 (mcap)"
  }
}
