{
  "$schema": "strategy-schema-v3.json",
  "id": "weekly_top10",
  "version": "1.0",
  "meta": {
    "name": "週度 TOP10 市值",
    "description": "前 10 大市值科技股，每週五等權重再平衡（與 top10 同邏輯，差別僅頻率）",
    "author": "itemhsu",
    "created_at": "2026-05-16",
    "tags": [
      "科技",
      "週度",
      "市值",
      "美股"
    ],
    "benchmark": "QQQ"
  },
  "universe": {
    "type": "single",
    "source": {
      "type": "inline",
      "symbols": [
        "AAPL",
        "MSFT",
        "NVDA",
        "GOOGL",
        "AMZN",
        "META",
        "TSM",
        "AVGO",
        "AMD",
        "ORCL",
        "CRM",
        "ADBE",
        "NFLX",
        "QCOM",
        "INTC",
        "TXN",
        "NOW",
        "UBER",
        "SNOW",
        "PLTR"
      ]
    }
  },
  "selection": {
    "method": "top_n_by_metric",
    "metric": "market_cap",
    "n": 10,
    "min_price": 5.0,
    "exclude_symbols": []
  },
  "portfolio": {
    "weighting": "equal",
    "target_n": 10,
    "min_weight_pct": 0.0,
    "max_weight_pct": 15.0,
    "cash_buffer_pct": 0.0,
    "custom_weights": null
  },
  "rebalancing": {
    "frequency": "weekly",
    "rebalance_on": "last_trading_day",
    "trigger": {
      "type": "any",
      "conditions": [
        {
          "kind": "scheduled"
        },
        {
          "kind": "composition_change"
        }
      ]
    },
    "min_trade_value_usd": 50,
    "order_type": "market",
    "sell_before_buy": true
  },
  "risk": {
    "max_single_position_pct": 15.0,
    "min_positions": 1,
    "allow_fractional_shares": false
  },
  "dashboard": {
    "title": "週度 TOP10 市值 Dashboard",
    "subtitle": "前 10 大市值科技股 · 等權重 · 每週五再平衡",
    "accent_color": "#10b981",
    "portfolio_label": "本週合格持股",
    "rankings": {
      "type": "market_cap_list",
      "title": "科技股市值排名",
      "show_top_n": 20
    },
    "extra_sections": []
  },
  "email": {
    "subject_template": "[Weekly #{account_id}] {date} NAV ${nav:,.0f} ({today_change_pct:+.2f}%)",
    "recipients_env": "EMAIL_RECIPIENT",
    "sections": [
      "header",
      "kpi",
      "strategy_card",
      "portfolio_badges",
      "positions_table",
      "rankings",
      "today_events",
      "trades",
      "cta",
      "footer"
    ]
  },
  "backtest": {
    "initial_cash": 100000,
    "start_date": "2010-01-01",
    "enabled": true,
    "color": "#ec4899",
    "group": "weekly",
    "order": 301,
    "label": "Top10 (weekly)"
  },
  "schema_version": "3.0.0"
}
